# Ignore IDE and editor-specific files
.idea/
.vscode/
*.iml
*.swp
.DS_Store

# Ignore log files and temporary files
*.log
tmp/
temp/
__pycache__/
*.bk*
*.backup
.ipynb_checkpoints/
.legacy_hr/*

# Ignore sensitive information (e.g., configuration files with credentials)
.auth/
config.local.js
.*env*
*cred*
token.pickle
token.json
credentials.json
*.json

# Ignore sensitive data
data/*
*.bin
src/data/chroma_db/*
tailwindcss
venv/
node_modules/

# Sensitive helper scripts removed from git history (2026-04-17).
# These files read from .auth/.env and must never be re-committed.
helper_scripts/check_status.py
helper_scripts/sync_secrets_gcp.sh
