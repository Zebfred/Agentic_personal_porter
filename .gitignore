# Ignore IDE and editor-specific files
.idea/
.vscode/
*.iml
*.swp
.DS_Store

# Ignore log files and temporary files
*.log
tmp/
temp/
__pycache__/
*.bk*
*.backup
.ipynb_checkpoints/
.legacy_hr/*
*.egg-info/

# Ignore sensitive information (e.g., configuration files with credentials)
.auth/
config.local.js
.*env*
*cred*
token.pickle
token.json
credentials.json
*.json
!package.json

# Ignore sensitive data
data/*
!data/category_mapping.example.json
*.bin
src/data/chroma_db/*
tailwindcss
venv/
node_modules/

#Ignore Scratch work
scratch/*
scripts/scratch/*

#ignore backups
.legacy_hr/*


#Potentially Sensitive documentation
Documentation/issues_and_audit/*
Documentation/Outdated_Doc/*
Documentation/notes/*
Documentation/Completed_Tasks/*
Documentation/Current_work/*

#
# Sensitive helper scripts removed from git history (2026-04-17).
# These files read from .auth/.env and must never be re-committed.
**/check_status.py
**/sync_gcp_secrets.sh
**/sync_gcp_secrets.ps1
